# Streame Environment Variables
# Copy this file to .env and fill in your values.
# Pass these at build time via --dart-define=KEY=VALUE

# TMDB API Key (required for metadata lookups)
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Real-Debrid Client ID (required for Real-Debrid OAuth login)
# Get one at https://real-debrid.com/apitoken
RD_CLIENT_ID=
