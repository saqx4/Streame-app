# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
packages/mobile/android/app/debug
packages/mobile/android/app/profile
packages/mobile/android/app/release
packages/tv/android/app/debug
packages/tv/android/app/profile
packages/tv/android/app/release

# Package build directories
packages/*/build/
packages/*/.dart_tool/
packages/*/.gradle/
packages/*/.flutter-plugins
packages/*/.flutter-plugins-dependencies
packages/*/android/.gradle/
packages/*/android/local.properties
packages/*/android/gradlew
packages/*/android/gradlew.bat
packages/*/android/gradle/wrapper/gradle-wrapper.jar
packages/*/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java
packages/*/.env

# Android signing
packages/mobile/android/release.keystore
packages/mobile/android/key.properties
packages/tv/android/release.keystore
packages/tv/android/key.properties

# Local environment secrets
.env
*.env

# Generated platform folders (CI creates linux/ & macos/ on the fly)
packages/desktop/linux/
packages/desktop/macos/

# Inno Setup output
installer/windows/Output/

# Build artifacts / tools (should not be in repo root)
*.AppImage
*.AppDir/
appimagetool
nuget.exe
