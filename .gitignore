# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# TorrServer binaries — CI downloads these automatically.
# For local dev, grab them from https://github.com/YouROK/TorrServer/releases
assets/bin/android/TorrServer*
assets/bin/windows/TorrServer*
assets/bin/linux/TorrServer
assets/bin/macos/TorrServer
android/app/src/main/jniLibs/*/libtorrserver.so

# Generated platform folders (CI creates linux/ & macos/ on the fly)
/linux/
/macos/

# Inno Setup output
installer/windows/Output/
